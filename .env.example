# ── WeChat Mini-Program ──
WECHAT_APPID=
WECHAT_SECRET=

# ── JWT ──
JWT_SECRET=change-me-in-production

# ── API Key (for POST /api/digests, PUT /api/config, admin endpoints) ──
API_KEY=

# ── Database ──
# SQLite (default, development):
DATABASE_URL=sqlite:///data/clawfeed.db
# MySQL (production):
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/clawfeed

# ── Server ──
DIGEST_PORT=8000
DIGEST_HOST=127.0.0.1
BASE_URL=https://clawfeed.kevinhe.io

# ── CORS ──
ALLOWED_ORIGINS=localhost,127.0.0.1

# ── Lark webhook for feedback notifications (optional) ──
FEEDBACK_LARK_WEBHOOK=

# ── LLM (OpenAI-compatible API) ──
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
# For DeepSeek: LLM_BASE_URL=https://api.deepseek.com/v1
# For OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-4o-mini

# ── Scheduler (APScheduler) ──
SCHEDULER_ENABLED=false
# Cron format: minute hour day_of_week day_of_month
SCHEDULE_4H=0 */4 * *
SCHEDULE_DAILY=0 8 * *
SCHEDULE_WEEKLY=0 9 0 *
SCHEDULE_MONTHLY=0 9 * 1
